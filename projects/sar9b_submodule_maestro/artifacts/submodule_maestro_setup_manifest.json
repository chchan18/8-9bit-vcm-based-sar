      "cell": "TB_SUBMOD_BOOTSTRAP_DIFF_PERF",
      "stop": "12n",
      "vars": {
        "vdd": "900m",
        "vcm": "450m",
        "vdiff": "100m",
        "cload": "5f"
      },
      "signals": [
        "/CLKS",
        "/CLKSB",
        "/VIP",
        "/VIN",
        "/VOUTP",
        "/VOUTN"
      ],
      "metrics": [
        {
          "name": "boot_diff_final_v",
          "expr": "value((VT(\"/VOUTP\")-VT(\"/VOUTN\")) 12e-09)",
          "unit": "V",
          "description": "Final sampled differential output"
        },
        {
          "name": "boot_diff_final_error_mv",
          "expr": "(value((VT(\"/VOUTP\")-VT(\"/VOUTN\")) 12e-09)-value((VT(\"/VIP\")-VT(\"/VIN\")) 12e-09))*1e3",
          "unit": "mV",
          "description": "Final differential tracking error"
        },
        {
          "name": "boot_track_error_on_avg_mv",
          "expr": "average(abs(clip((VT(\"/VOUTP\")-VT(\"/VOUTN\"))-(VT(\"/VIP\")-VT(\"/VIN\")) 0.55e-09 2.5e-09)))*1e3",
          "unit": "mV",
          "description": "Average absolute tracking error during the first on window"
        },
        {
          "name": "boot_track_error_on_max_mv",
          "expr": "ymax(abs(clip((VT(\"/VOUTP\")-VT(\"/VOUTN\"))-(VT(\"/VIP\")-VT(\"/VIN\")) 0.55e-09 2.5e-09)))*1e3",
          "unit": "mV",
          "description": "Peak absolute tracking error during the first on window"
        },
        {
          "name": "boot_settle_error_2p5n_mv",
          "expr": "value(abs((VT(\"/VOUTP\")-VT(\"/VOUTN\"))-(VT(\"/VIP\")-VT(\"/VIN\"))) 2.5e-09)*1e3",
          "unit": "mV",
          "description": "Tracking error near the end of the first on window"
        },
        {
          "name": "boot_clk_overlap_product_peak_v2",
          "expr": "ymax(VT(\"/CLKS\")*VT(\"/CLKSB\"))",
          "unit": "V^2",
          "description": "Peak product of complementary bootstrap clocks"
        }
      ],
      "offline_metrics": [
        {
