{
  "library": "SAR9B_400MV",
  "test_name": "TRAN",
  "model_file": "/home/IC/Desktop/Project/project_tsmcN28_NEW/project_tsmcN28_NEW/iPDK_CRN28HPC+_v1.0_2p2a_20160226_all/CRN28HPCp/models/spectre/toplevel.scs",
  "testbenches": [
    {
      "cell": "TB_SUBMOD_COMPARATOR_PERF",
      "stop": "8n",
      "vars": {
        "vdd": "900m",
        "vcm": "450m",
        "vdiff": "10m",
        "cload": "2f"
      },
      "signals": [
        "/CLKC",
        "/VP",
        "/VN",
        "/VOP",
        "/VON"
      ],
      "metrics": [
        {
          "name": "cmp_clk_rise_s",
          "expr": "cross(VT(\"/CLKC\") 0.45 1 \"rising\" nil nil)",
          "unit": "s",
          "description": "First comparator clock rising threshold crossing"
        },
        {
          "name": "cmp_decision_cross_s",
          "expr": "cross((VT(\"/VOP\")-VT(\"/VON\")) 0 1 \"rising\" nil nil)",
          "unit": "s",
          "description": "First differential output zero crossing"
        },
        {
          "name": "cmp_decision_delay_ps",
          "expr": "(cross((VT(\"/VOP\")-VT(\"/VON\")) 0 1 \"rising\" nil nil)-cross(VT(\"/CLKC\") 0.45 1 \"rising\" nil nil))*1e12",
          "unit": "ps",
          "description": "Clock-to-decision delay"
        },
        {
          "name": "cmp_vop_max_v",
          "expr": "ymax(VT(\"/VOP\"))",
          "unit": "V",
          "description": "Maximum VOP swing"
        },
        {
          "name": "cmp_von_min_v",
          "expr": "ymin(VT(\"/VON\"))",
          "unit": "V",
          "description": "Minimum VON swing"
        },
        {
          "name": "cmp_final_diff_v",
          "expr": "value((VT(\"/VOP\")-VT(\"/VON\")) 8e-09)",
          "unit": "V",
          "description": "Final differential output at stop time"
        }
      ],
      "offline_metrics": [
        {
          "name": "cmp_avg_power_w",
          "unit": "W",
          "description": "Average positive supply power over the transient run",
          "source": "vdd_current_a",
          "waveform_expr": "getData(\"/VDD_SRC/PLUS\" ?result \"tran\")",
          "operation": "avg_power_from_supply_current",
          "vdd": "0.9"
        },
        {
          "name": "cmp_energy_j",
          "unit": "J",
          "description": "Positive supply energy over the transient run",
          "source": "vdd_current_a",
          "waveform_expr": "getData(\"/VDD_SRC/PLUS\" ?result \"tran\")",
          "operation": "energy_from_supply_current",
          "vdd": "0.9"
        }
      ]
    },
    {
      "cell": "TB_SUBMOD_CLK_NOOVERLAP_PERF",
      "stop": "12n",
      "vars": {
        "vdd": "900m",
        "cload": "2f"
      },
      "signals": [
        "/CLKIN",
        "/CLKOP",
        "/CLKON"
      ],
      "metrics": [
        {
          "name": "clk_clkop_delay_ps",
          "expr": "(cross(VT(\"/CLKOP\") 0.45 1 \"rising\" nil nil)-cross(VT(\"/CLKIN\") 0.45 1 \"rising\" nil nil))*1e12",
          "unit": "ps",
          "description": "CLKIN rising to CLKOP rising delay"
        },
        {
          "name": "clk_clkon_delay_ps",
          "expr": "(cross(VT(\"/CLKON\") 0.45 1 \"rising\" nil nil)-cross(VT(\"/CLKIN\") 0.45 1 \"rising\" nil nil))*1e12",
          "unit": "ps",
          "description": "CLKIN rising to CLKON rising delay"
        },
        {
          "name": "clk_gap_op_after_on_ps",
          "expr": "(cross(VT(\"/CLKOP\") 0.45 1 \"rising\" nil nil)-cross(VT(\"/CLKON\") 0.45 1 \"falling\" nil nil))*1e12",
          "unit": "ps",
          "description": "Low-low non-overlap gap before CLKOP turns on"
        },
        {
          "name": "clk_gap_on_after_op_ps",
          "expr": "(cross(VT(\"/CLKON\") 0.45 1 \"rising\" nil nil)-cross(VT(\"/CLKOP\") 0.45 1 \"falling\" nil nil))*1e12",
          "unit": "ps",
          "description": "Low-low non-overlap gap before CLKON turns on"
        },
        {
          "name": "clk_clkop_duty_pct",
          "expr": "(cross(VT(\"/CLKOP\") 0.45 1 \"falling\" nil nil)-cross(VT(\"/CLKOP\") 0.45 1 \"rising\" nil nil))/5e-09*100",
          "unit": "%",
          "description": "First full CLKOP high-window duty cycle"
        },
        {
          "name": "clk_clkon_duty_pct",
          "expr": "(cross(VT(\"/CLKON\") 0.45 2 \"falling\" nil nil)-cross(VT(\"/CLKON\") 0.45 1 \"rising\" nil nil))/5e-09*100",
          "unit": "%",
          "description": "First full CLKON high-window duty cycle"
        },
        {
          "name": "clk_overlap_product_peak_v2",
          "expr": "ymax(VT(\"/CLKOP\")*VT(\"/CLKON\"))",
          "unit": "V^2",
          "description": "Peak product of both phase clocks; near zero indicates no simultaneous high state"
        }
      ],
      "offline_metrics": [
        {
          "name": "clk_avg_power_w",
          "unit": "W",
          "description": "Average positive supply power over the transient run",
          "source": "vdd_current_a",
          "waveform_expr": "getData(\"/VDD_SRC/PLUS\" ?result \"tran\")",
          "operation": "avg_power_from_supply_current",
          "vdd": "0.9"
        },
        {
          "name": "clk_energy_j",
          "unit": "J",
          "description": "Positive supply energy over the transient run",
          "source": "vdd_current_a",
          "waveform_expr": "getData(\"/VDD_SRC/PLUS\" ?result \"tran\")",
          "operation": "energy_from_supply_current",
          "vdd": "0.9"
        }
      ]
    },
